<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Weather Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1e2730;
    --border: #30363d;
    --text: #e6edf3;
    --text-muted: #7d8590;
    --text-dim: #404650;
    --blue: #58a6ff;
    --cyan: #39d353;
    --orange: #f0883e;
    --yellow: #d29922;
    --radius: 12px;
    --font: 'Outfit', sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 2rem;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .logo {
    font-family: var(--mono);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--blue);
  }

  .search-bar {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    max-width: 400px;
  }

  input[type="text"] {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--font);
    font-size: 0.875rem;
    padding: 0.6rem 1rem;
    outline: none;
    transition: border-color 0.15s;
  }

  input[type="text"]:focus { border-color: var(--blue); }
  input[type="text"]::placeholder { color: var(--text-dim); }

  .btn {
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
    background: var(--blue);
    color: #0d1117;
  }

  .btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  .grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; margin-bottom: 1rem; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }

  .card-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .main-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    grid-column: span 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .city-name {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .city-meta {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .temp-display {
    text-align: right;
  }

  .temp-big {
    font-family: var(--mono);
    font-size: 4rem;
    font-weight: 500;
    line-height: 1;
    color: var(--blue);
  }

  .temp-feels {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .weather-icon {
    font-size: 4rem;
    line-height: 1;
  }

  .condition {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .stat-value {
    font-family: var(--mono);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text);
  }

  .stat-unit {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .forecast-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: center;
  }

  .forecast-day {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .forecast-icon { font-size: 1.75rem; margin-bottom: 8px; }

  .forecast-temps {
    display: flex;
    justify-content: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 0.85rem;
  }

  .forecast-high { color: var(--orange); font-weight: 500; }
  .forecast-low { color: var(--text-muted); }

  .forecast-cond {
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-top: 4px;
  }

  .bar-container {
    height: 6px;
    background: var(--surface2);
    border-radius: 99px;
    overflow: hidden;
    margin-top: 8px;
  }

  .bar-fill {
    height: 100%;
    border-radius: 99px;
    background: var(--blue);
    transition: width 0.8s ease;
  }

  .history-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.875rem;
    cursor: pointer;
    transition: color 0.15s;
  }

  .history-item:last-child { border-bottom: none; }
  .history-item:hover { color: var(--blue); }
  .history-item span { color: var(--text-dim); font-size: 0.75rem; }

  .unit-toggle {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .unit-btn {
    padding: 4px 10px;
    border-radius: 6px;
    font-family: var(--mono);
    font-size: 0.8rem;
    cursor: pointer;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    transition: all 0.15s;
  }

  .unit-btn.active { background: var(--blue); border-color: var(--blue); color: #0d1117; }

  .wind-dir {
    font-size: 1.5rem;
    display: inline-block;
    transition: transform 0.5s ease;
  }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .animate { animation: fadeIn 0.4s ease; }
</style>
</head>
<body>

<header>
  <div class="logo">weather<span style="color:var(--text-muted)">/</span>dash</div>
  <div class="search-bar">
    <input type="text" id="search-input" placeholder="Search city..." onkeydown="if(event.key==='Enter')search()"/>
    <button class="btn" onclick="search()">Search</button>
  </div>
  <div class="unit-toggle">
    <button class="unit-btn active" id="btn-f" onclick="setUnit('F')">°F</button>
    <button class="unit-btn" id="btn-c" onclick="setUnit('C')">°C</button>
  </div>
</header>

<div id="dashboard" class="animate">
  <div class="grid" style="margin-bottom:1rem">
    <div class="main-card" id="main-card">
      <div>
        <div class="city-name" id="city-name">College Park, MD</div>
        <div class="city-meta" id="city-meta">United States · Updated just now</div>
        <div class="condition" id="condition">Partly Cloudy</div>
      </div>
      <div style="display:flex;align-items:center;gap:1.5rem">
        <div class="weather-icon" id="weather-icon">⛅</div>
        <div class="temp-display">
          <div class="temp-big" id="temp-big">72°</div>
          <div class="temp-feels" id="temp-feels">Feels like 69°</div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid-3" style="margin-bottom:1rem">
    <div class="card">
      <div class="card-label">Humidity</div>
      <div class="stat-value" id="humidity">58%</div>
      <div class="bar-container"><div class="bar-fill" id="humidity-bar" style="width:58%;background:#58a6ff"></div></div>
      <div class="stat-unit">Comfortable range</div>
    </div>
    <div class="card">
      <div class="card-label">Wind</div>
      <div style="display:flex;align-items:center;gap:8px">
        <span class="wind-dir" id="wind-dir" style="transform:rotate(45deg)">↑</span>
        <div class="stat-value" id="wind-speed">12 mph</div>
      </div>
      <div class="stat-unit" id="wind-dir-label">NE direction</div>
    </div>
    <div class="card">
      <div class="card-label">Visibility</div>
      <div class="stat-value" id="visibility">10 mi</div>
      <div class="stat-unit">Clear conditions</div>
    </div>
  </div>

  <div class="grid-3" style="margin-bottom:1rem">
    <div class="card">
      <div class="card-label">UV Index</div>
      <div class="stat-value" id="uv-index">5</div>
      <div class="bar-container"><div class="bar-fill" id="uv-bar" style="width:50%;background:#f0883e"></div></div>
      <div class="stat-unit" id="uv-label">Moderate</div>
    </div>
    <div class="card">
      <div class="card-label">Pressure</div>
      <div class="stat-value" id="pressure">1013 hPa</div>
      <div class="stat-unit">Normal range</div>
    </div>
    <div class="card">
      <div class="card-label">Dew Point</div>
      <div class="stat-value" id="dew-point">54°</div>
      <div class="stat-unit">Comfortable</div>
    </div>
  </div>

  <div style="margin-bottom:0.5rem;font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim)">5-Day Forecast</div>
  <div class="grid-5" id="forecast"></div>

  <div class="grid">
    <div class="card">
      <div class="card-label">Recent Searches</div>
      <div id="history-list"></div>
    </div>
    <div class="card">
      <div class="card-label">Sun Schedule</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.5rem">
        <div style="text-align:center">
          <div style="font-size:1.5rem">🌅</div>
          <div style="font-family:var(--mono);font-size:1rem;margin-top:4px" id="sunrise">6:24 AM</div>
          <div style="font-size:0.7rem;color:var(--text-dim);margin-top:2px">Sunrise</div>
        </div>
        <div style="flex:1;height:2px;background:linear-gradient(to right,var(--yellow),var(--orange),var(--yellow));margin:0 1rem;border-radius:99px"></div>
        <div style="text-align:center">
          <div style="font-size:1.5rem">🌇</div>
          <div style="font-family:var(--mono);font-size:1rem;margin-top:4px" id="sunset">7:48 PM</div>
          <div style="font-size:0.7rem;color:var(--text-dim);margin-top:2px">Sunset</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const CITIES = {
  "college park": { name: "College Park, MD", country: "United States", temp_f: 72, feels_f: 69, condition: "Partly Cloudy", icon: "⛅", humidity: 58, wind: 12, wind_dir: "NE", wind_deg: 45, visibility: 10, uv: 5, pressure: 1013, dew_f: 54, sunrise: "6:24 AM", sunset: "7:48 PM" },
  "new york": { name: "New York, NY", country: "United States", temp_f: 68, feels_f: 65, condition: "Sunny", icon: "☀️", humidity: 45, wind: 8, wind_dir: "SW", wind_deg: 225, visibility: 10, uv: 7, pressure: 1018, dew_f: 48, sunrise: "5:58 AM", sunset: "8:02 PM" },
  "los angeles": { name: "Los Angeles, CA", country: "United States", temp_f: 82, feels_f: 80, condition: "Clear", icon: "☀️", humidity: 30, wind: 5, wind_dir: "W", wind_deg: 270, visibility: 10, uv: 9, pressure: 1015, dew_f: 45, sunrise: "6:12 AM", sunset: "7:55 PM" },
  "chicago": { name: "Chicago, IL", country: "United States", temp_f: 61, feels_f: 57, condition: "Cloudy", icon: "☁️", humidity: 70, wind: 18, wind_dir: "N", wind_deg: 0, visibility: 8, uv: 3, pressure: 1005, dew_f: 52, sunrise: "5:48 AM", sunset: "8:12 PM" },
  "miami": { name: "Miami, FL", country: "United States", temp_f: 88, feels_f: 95, condition: "Thunderstorm", icon: "⛈️", humidity: 85, wind: 14, wind_dir: "SE", wind_deg: 135, visibility: 5, uv: 6, pressure: 1008, dew_f: 76, sunrise: "6:30 AM", sunset: "7:42 PM" },
  "london": { name: "London", country: "United Kingdom", temp_f: 55, feels_f: 51, condition: "Rainy", icon: "🌧️", humidity: 80, wind: 15, wind_dir: "W", wind_deg: 270, visibility: 6, uv: 2, pressure: 998, dew_f: 49, sunrise: "5:10 AM", sunset: "9:05 PM" },
  "tokyo": { name: "Tokyo", country: "Japan", temp_f: 77, feels_f: 74, condition: "Partly Cloudy", icon: "⛅", humidity: 65, wind: 10, wind_dir: "E", wind_deg: 90, visibility: 9, uv: 6, pressure: 1012, dew_f: 63, sunrise: "4:45 AM", sunset: "6:50 PM" },
  "paris": { name: "Paris", country: "France", temp_f: 62, feels_f: 59, condition: "Overcast", icon: "🌥️", humidity: 72, wind: 11, wind_dir: "SW", wind_deg: 225, visibility: 7, uv: 3, pressure: 1002, dew_f: 53, sunrise: "5:50 AM", sunset: "9:30 PM" },
};

const FORECASTS = {
  sunny: [
    { icon: "☀️", cond: "Sunny", hi: 5, lo: -3 },
    { icon: "⛅", cond: "P. Cloudy", hi: 3, lo: -4 },
    { icon: "🌥️", cond: "Cloudy", hi: -1, lo: -6 },
    { icon: "🌧️", cond: "Rainy", hi: -5, lo: -8 },
    { icon: "⛅", cond: "P. Cloudy", hi: 2, lo: -3 },
  ],
  cloudy: [
    { icon: "🌥️", cond: "Cloudy", hi: 2, lo: -2 },
    { icon: "🌧️", cond: "Rainy", hi: -3, lo: -6 },
    { icon: "⛈️", cond: "Storms", hi: -6, lo: -9 },
    { icon: "🌥️", cond: "Cloudy", hi: 0, lo: -4 },
    { icon: "⛅", cond: "P. Cloudy", hi: 4, lo: -1 },
  ],
  rainy: [
    { icon: "🌧️", cond: "Rainy", hi: -2, lo: -5 },
    { icon: "⛈️", cond: "Storms", hi: -5, lo: -8 },
    { icon: "🌥️", cond: "Cloudy", hi: 1, lo: -3 },
    { icon: "⛅", cond: "P. Cloudy", hi: 4, lo: -1 },
    { icon: "☀️", cond: "Sunny", hi: 7, lo: 0 },
  ],
};

const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
let unit = 'F';
let currentCity = null;
let history = [];

function toC(f) { return Math.round((f - 32) * 5/9); }
function fmt(f) { return unit === 'F' ? f + '°F' : toC(f) + '°C'; }
function fmtShort(f) { return unit === 'F' ? f + '°' : toC(f) + '°'; }

function setUnit(u) {
  unit = u;
  document.getElementById('btn-f').classList.toggle('active', u === 'F');
  document.getElementById('btn-c').classList.toggle('active', u === 'C');
  if (currentCity) renderCity(currentCity);
}

function search() {
  const query = document.getElementById('search-input').value.trim().toLowerCase();
  const city = CITIES[query] || CITIES[Object.keys(CITIES).find(k => k.includes(query.split(',')[0].trim()))];
  if (city) {
    loadCity(city);
    document.getElementById('search-input').value = '';
  } else {
    document.getElementById('search-input').style.borderColor = '#f87171';
    setTimeout(() => document.getElementById('search-input').style.borderColor = '', 1000);
  }
}

function loadCity(city) {
  currentCity = city;
  if (!history.includes(city.name)) {
    history.unshift(city.name);
    if (history.length > 5) history.pop();
  }
  renderCity(city);
  renderHistory();
}

function renderCity(city) {
  document.getElementById('city-name').textContent = city.name;
  document.getElementById('city-meta').textContent = `${city.country} · Updated just now`;
  document.getElementById('condition').textContent = city.condition;
  document.getElementById('weather-icon').textContent = city.icon;
  document.getElementById('temp-big').textContent = fmtShort(city.temp_f);
  document.getElementById('temp-feels').textContent = `Feels like ${fmtShort(city.feels_f)}`;
  document.getElementById('humidity').textContent = city.humidity + '%';
  document.getElementById('humidity-bar').style.width = city.humidity + '%';
  document.getElementById('wind-speed').textContent = city.wind + ' mph';
  document.getElementById('wind-dir-label').textContent = city.wind_dir + ' direction';
  document.getElementById('wind-dir').style.transform = `rotate(${city.wind_deg}deg)`;
  document.getElementById('visibility').textContent = city.visibility + ' mi';
  document.getElementById('uv-index').textContent = city.uv;
  document.getElementById('uv-bar').style.width = (city.uv / 11 * 100) + '%';
  document.getElementById('uv-label').textContent = city.uv <= 2 ? 'Low' : city.uv <= 5 ? 'Moderate' : city.uv <= 7 ? 'High' : 'Very High';
  document.getElementById('pressure').textContent = city.pressure + ' hPa';
  document.getElementById('dew-point').textContent = fmtShort(city.dew_f);
  document.getElementById('sunrise').textContent = city.sunrise;
  document.getElementById('sunset').textContent = city.sunset;
  renderForecast(city);
  document.getElementById('dashboard').classList.remove('animate');
  void document.getElementById('dashboard').offsetWidth;
  document.getElementById('dashboard').classList.add('animate');
}

function renderForecast(city) {
  const cond = city.condition.toLowerCase();
  const template = cond.includes('sun') || cond.includes('clear') ? FORECASTS.sunny : cond.includes('rain') || cond.includes('storm') ? FORECASTS.rainy : FORECASTS.cloudy;
  const today = new Date().getDay();
  document.getElementById('forecast').innerHTML = template.map((f, i) => {
    const day = DAYS[(today + i + 1) % 7];
    const hi = city.temp_f + f.hi;
    const lo = city.temp_f + f.lo;
    return `
      <div class="forecast-card">
        <div class="forecast-day">${day}</div>
        <div class="forecast-icon">${f.icon}</div>
        <div class="forecast-temps">
          <span class="forecast-high">${fmtShort(hi)}</span>
          <span class="forecast-low">${fmtShort(lo)}</span>
        </div>
        <div class="forecast-cond">${f.cond}</div>
      </div>`;
  }).join('');
}

function renderHistory() {
  document.getElementById('history-list').innerHTML = history.length === 0
    ? '<div style="color:var(--text-dim);font-size:0.8rem;padding:0.5rem 0">No searches yet</div>'
    : history.map(h => `
      <div class="history-item" onclick="loadCity(CITIES[Object.keys(CITIES).find(k => CITIES[k].name === '${h}')])">
        ${h} <span>↗</span>
      </div>`).join('');
}

loadCity(CITIES["college park"]);
</script>
</body>
</html>
